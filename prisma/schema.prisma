generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id                String       @id @default(cuid())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  name              String
  phone             String?
  clerkUserId       String?      @unique
  twilioNumber      String?      @unique
  address           String?
  estimatedPrepTime Int?         @default(20)
  deliveryEnabled   Boolean      @default(true)
  deliveryFee       Float?       @default(0)
  deliveryMinimum   Float?       @default(0)
  paymentMethods    String?      @default("CB, espèces")
  vacationMode      Boolean      @default(false)
  vacationMessage   String?      @default("Le restaurant est actuellement fermé. Merci de rappeler.")
  openingHours      Json?
  allergensInfo     String?
  currentPromos     String?
  welcomeMessage    String?
  orders            Order[]
  menuItems         MenuItem[]
  supplements       Supplement[]
}

model MenuItem {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  category     String
  name         String
  description  String?
  price        Float
  available    Boolean    @default(true)
  sizePrices   Json?

  @@index([restaurantId])
}

model Supplement {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  name         String
  price        Float      @default(0)
  available    Boolean    @default(true)

  @@index([restaurantId])
}

model Conversation {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  externalId String?  @unique
  messages   Json?
  transcript String?
}

model Order {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now())
  clientOrderId String?     @unique
  extras        String      @default("")
  product       String      @default("")
  size          String      @default("")
  status        String      @default("draft")
  total         Float       @default(0)
  type          String      @default("takeaway")
  address       String?
  customerName  String?
  phone         String?
  restaurantId  String?
  restaurant    Restaurant? @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
}
